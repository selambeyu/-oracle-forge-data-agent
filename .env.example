# Copy this to .env and fill in your values
# Never commit .env

# Optional: only needed for live LLM-backed runs, not for the test suite
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite
TOOLBOX_URL=http://127.0.0.1:5000
DAB_DATASET_ROOT=/home/your-user/DataAgentBench
DUCKDB_MCP_URL=http://127.0.0.1:8001

# PostgreSQL (shared Docker container)
# Preferred Worker secret / connection string
POSTGRES_URL=postgresql://postgres:password@127.0.0.1:55432/bookreview_db

# Optional component-style fallback
PG_HOST=127.0.0.1
PG_PORT=55432
PG_DATABASE=bookreview_db
PG_USER=postgres
PG_PASSWORD=teampalm

# MongoDB (shared Docker container)
# Preferred Worker secret
MONGODB_URI=mongodb://127.0.0.1:57017
MONGODB_DATABASE=yelp_db

# Optional legacy fallback names
MONGO_URI=mongodb://127.0.0.1:57017
MONGO_DATABASE=yelp_db

# DuckDB (direct file path)
DUCKDB_PATH=./data/dataset.duckdb

# Cloudflare Sandbox
SANDBOX_URL=
